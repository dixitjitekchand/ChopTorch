<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="72dp"
    android:height="72dp"
    android:viewportWidth="72"
    android:viewportHeight="72">

    <!--
        High-contrast smartphone + flashlight icon.
        Hardcoded colors — no theme attribute references — so it renders
        correctly on the app's dark background (#111318) and any other bg.

        Layers (bottom → top):
          1. Ambient glow halo behind the beam
          2. Outer beam cone (soft yellow, semi-transparent)
          3. Mid beam cone (more opaque)
          4. Beam core (bright, narrow)
          5. Phone body (light slate, clearly visible on dark bg)
          6. Phone screen (darker inset)
          7. Camera module bump
          8. Lens ring
          9. LED bright dot
         10. Home pill indicator
         11. Sparkle glints on beam edges
    -->

    <!-- ── 1. Ambient glow halo (soft circle behind beam origin) ───────── -->
    <path
        android:fillColor="#33FFE566"
        android:pathData="
            M36,18
            m-14,0
            a14,14 0 1,0 28,0
            a14,14 0 1,0 -28,0" />

    <!-- ── 2. Outer beam cone — wide, low opacity warm yellow ──────────── -->
    <path
        android:fillColor="#44FFDD44"
        android:pathData="
            M36,20
            L10,2
            L8,2 L8,0
            L64,0 L64,2
            L62,2
            Z" />

    <!-- ── 3. Mid beam cone — narrower, more opaque ───────────────────── -->
    <path
        android:fillColor="#88FFCC22"
        android:pathData="
            M36,20
            L16,2
            L56,2
            Z" />

    <!-- ── 4. Beam core — bright narrow ray ───────────────────────────── -->
    <path
        android:fillColor="#EEFFF0AA"
        android:pathData="
            M36,20
            L28,2
            L44,2
            Z" />

    <!-- ── 5. Phone body — light blue-grey, high contrast on dark bg ──── -->
    <!--
        Body: x=20, y=20, width=32, height=50, corner=5
        Rendered as a rounded rect path.
    -->
    <path
        android:fillColor="#FFB0BEC5"
        android:pathData="
            M25,20
            L47,20
            Q52,20 52,25
            L52,65
            Q52,70 47,70
            L25,70
            Q20,70 20,65
            L20,25
            Q20,20 25,20
            Z" />

    <!-- ── 6. Phone screen — dark inset ───────────────────────────────── -->
    <path
        android:fillColor="#FF1A2332"
        android:pathData="
            M22,28
            L50,28
            L50,62
            L22,62
            Z" />

    <!-- Screen inner highlight (subtle blue tint to suggest display) -->
    <path
        android:fillColor="#0D4FC3F7"
        android:pathData="
            M22,28
            L50,28
            L50,44
            L22,44
            Z" />

    <!-- ── 7. Camera module bump (top-centre of phone body) ────────────── -->
    <path
        android:fillColor="#FF263544"
        android:pathData="
            M36,20
            m-5,0
            a5,5 0 1,0 10,0
            a5,5 0 1,0 -10,0" />

    <!-- ── 8. Lens ring ─────────────────────────────────────────────────── -->
    <!-- Outer ring fill -->
    <path
        android:fillColor="#FF3A5068"
        android:pathData="
            M36,20
            m-3.5,0
            a3.5,3.5 0 1,0 7,0
            a3.5,3.5 0 1,0 -7,0" />

    <!-- Ring centre cutout to show only ring stroke -->
    <path
        android:fillColor="#FF263544"
        android:pathData="
            M36,20
            m-2.2,0
            a2.2,2.2 0 1,0 4.4,0
            a2.2,2.2 0 1,0 -4.4,0" />

    <!-- ── 9. LED — bright glowing dot (flashlight ON) ─────────────────── -->
    <!-- Outer glow -->
    <path
        android:fillColor="#CCFFEE44"
        android:pathData="
            M36,20
            m-2.8,0
            a2.8,2.8 0 1,0 5.6,0
            a2.8,2.8 0 1,0 -5.6,0" />
    <!-- Bright core -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="
            M36,20
            m-1.4,0
            a1.4,1.4 0 1,0 2.8,0
            a1.4,1.4 0 1,0 -2.8,0" />

    <!-- ── 10. Screen UI hint — three horizontal content bars ──────────── -->
    <path
        android:fillColor="#33FFFFFF"
        android:pathData="M26,34 L46,34 Q47,34 47,35 L47,36 Q47,37 46,37 L26,37 Q25,37 25,36 L25,35 Q25,34 26,34 Z" />
    <path
        android:fillColor="#26FFFFFF"
        android:pathData="M26,41 L42,41 Q43,41 43,42 L43,43 Q43,44 42,44 L26,44 Q25,44 25,43 L25,42 Q25,41 26,41 Z" />
    <path
        android:fillColor="#1AFFFFFF"
        android:pathData="M26,48 L38,48 Q39,48 39,49 L39,50 Q39,51 38,51 L26,51 Q25,51 25,50 L25,49 Q25,48 26,48 Z" />

    <!-- ── 11. Home indicator pill ──────────────────────────────────────── -->
    <path
        android:fillColor="#88FFFFFF"
        android:pathData="M30,66 L42,66 Q43,66 43,67.2 Q43,68.5 42,68.5 L30,68.5 Q29,68.5 29,67.2 Q29,66 30,66 Z" />

    <!-- ── 12. Beam sparkle glints (left + right of beam edges) ────────── -->
    <!-- Left glint -->
    <path
        android:fillColor="#CCFFE566"
        android:pathData="M19,8 L21,6 L21,10 Z" />
    <!-- Right glint -->
    <path
        android:fillColor="#CCFFE566"
        android:pathData="M53,8 L51,6 L51,10 Z" />
    <!-- Top-center glint -->
    <path
        android:fillColor="#BBFFFFFF"
        android:pathData="M36,1 L37.2,3 L34.8,3 Z" />

</vector>
